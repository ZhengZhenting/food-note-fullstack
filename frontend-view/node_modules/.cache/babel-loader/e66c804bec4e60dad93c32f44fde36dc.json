,GAAA;AACA,WAAA,UAAA,GAAA,EAAA;AACA,WAAA,gBAAA;AACA,KARA;;AASA;AACA,IAAA,gBAAA,CAAA,GAAA,EAAA;AACA,WAAA,QAAA,GAAA,GAAA;AACA,WAAA,WAAA,GAAA,CAAA;AACA,WAAA,gBAAA;AACA,KAdA;;AAeA;AACA,IAAA,mBAAA,CAAA,GAAA,EAAA;AACA,WAAA,WAAA,GAAA,GAAA;AACA,WAAA,gBAAA;AACA,KAnBA;;AAoBA;AACA,IAAA,gBAAA,CAAA,QAAA,EAAA;AACA,WAAA,aAAA,GAAA,QAAA;AACA,WAAA,eAAA,CAAA,UAAA,GAAA,QAAA,CAAA,EAAA;AACA,WAAA,gBAAA;AACA,KAzBA;;AA0BA;AACA,IAAA,iBAAA,GAAA;AACA,WAAA,MAAA,CAAA,IAAA,CAAA,gBAAA,EAAA,EAAA,EAAA,IAAA,CAAA,GAAA,IAAA;AACA,cAAA;AAAA,UAAA;AAAA,YAAA,GAAA;;AACA,YAAA,IAAA,CAAA,IAAA,KAAA,GAAA,EAAA;AACA,eAAA,UAAA,GAAA,GAAA,CAAA,IAAA,CAAA,IAAA;AACA,eAAA,UAAA,CAAA,OAAA,CAAA,KAAA,aAAA;AACA;AACA,OANA,EAMA,KANA,CAMA,KAAA,IAAA;AACA,QAAA,OAAA,CAAA,GAAA,CAAA,KAAA;AACA,OARA;AASA,KArCA;;AAuCA;AACA,IAAA,gBAAA,GAAA;AACA;AACA,YAAA,QAAA,GAAA;AACA,QAAA,OAAA,EAAA,KAAA,WADA;AAEA,QAAA,IAAA,EAAA,KAAA,QAFA;AAGA,QAAA,GAAA,EAAA,KAAA,UAHA;AAIA,WAAA,KAAA;AAJA,OAAA;AAMA,WAAA,MAAA,CAAA,IAAA,CAAA,mBAAA,EAAA,QAAA,EAAA,IAAA,CAAA,GAAA,IAAA;AACA,cAAA;AAAA,UAAA;AAAA,YAAA,GAAA;;AACA,YAAA,IAAA,CAAA,IAAA,KAAA,GAAA,EAAA;AACA,eAAA,WAAA,GAAA,GAAA,CAAA,IAAA,CAAA,IAAA;AACA,eAAA,UAAA,GAAA,IAAA,CAAA,KAAA;AACA;AACA,OANA,EAMA,KANA,CAMA,KAAA,IAAA;AACA,QAAA,OAAA,CAAA,GAAA,CAAA,KAAA;AACA,OARA;AASA;;AAzDA;AAlBA,CAAA","sourcesContent":["<template>\r\n    <div class=\"text\">\r\n        <div>\r\n            <div style=\"height: 200px; background-color: #f0f0f0; text-align: center;\">\r\n                <h2>recommendationes //TODO</h2>\r\n            </div>\r\n            <div style=\"text-align: left; display: block; margin: 20px 0;\">\r\n                <span style=\"font-size: 24px; font-weight: bold;\"> Search </span>\r\n                <el-input size=\"small\" style=\"width: 166px;\" v-model=\"gourmetQueryDto.title\" placeholder=\"title\"\r\n                    clearable @clear=\"handleFilterClear\">\r\n                    <el-button slot=\"append\" @click=\"fetchGourmetData\" icon=\"el-icon-search\"></el-button>\r\n                </el-input>\r\n            </div>\r\n            <div style=\"margin-block: 20px; text-align: left; display: block;\">\r\n                <span :style=\"{\r\n                    backgroundColor: categoryClick.id === category.id ? '#0d559e' : '',\r\n                    color: categoryClick.id === category.id ? 'rgb(245,245,245)' : ''\r\n                }\" @click=\"categorySelected(category)\" class=\"item-category\" v-for=\"(category, index) in categories\"\r\n                    :key=\"index\">\r\n                    {{ category.name }}\r\n                </span>\r\n            </div>\r\n            <div v-if=\"gourmetList.length === 0\">\r\n                <el-empty description=\"No data\"></el-empty>\r\n            </div>\r\n            <div>\r\n                <div class=\"item-gourmet\" v-for=\"(gourmet, index) in gourmetList\" :key=\"index\">\r\n                    <div class=\"left\">\r\n                        <img :src=\"gourmet.cover\">\r\n                    </div>\r\n                    <div class=\"right\">\r\n                        <div class=\"info\">\r\n                            <img style=\"width: 25px; height: 25px; border-radius: 50%;\" :src=\"gourmet.userAvatar\">\r\n                            <span>{{ gourmet.userName }}</span>\r\n                        </div>\r\n                        <div class=\"title\" @click=\"readGourmet(gourmet)\">\r\n                            {{ gourmet.title }}\r\n                        </div>\r\n                        <div class=\"detail\">\r\n                            {{ gourmet.detail }}\r\n                        </div>\r\n                        <div class=\"detail\">\r\n                            <span> {{ gourmet.createTime }}</span>\r\n                            <span> Views({{ gourmet.viewCount }})</span>\r\n                            <span> Likes({{ gourmet.upvoteCount }})</span>\r\n                            <span> Saves({{ gourmet.saveCount }})</span>\r\n                            <span> Rating({{ gourmet.rating }})</span>\r\n                        </div>\r\n                    </div>\r\n\r\n                </div>\r\n            </div>\r\n            <el-pagination style=\"margin:10px 0;float: right;\" @size-change=\"handleSizeChange\"\r\n                @current-change=\"handleCurrentChange\" :current-page=\"currentPage\" :page-sizes=\"[10, 20]\"\r\n                :page-size=\"pageSize\" layout=\"total, sizes, prev, pager, next, jumper\"\r\n                :total=\"totalItems\"></el-pagination>\r\n        </div>\r\n\r\n    </div>\r\n</template>\r\n<script>\r\nexport default {\r\n    name: \"Gourmet\",\r\n    data() {\r\n        return {\r\n            gourmetQueryDto: {},\r\n            gourmetList: [],\r\n            categories: [],\r\n            filterText: '',\r\n            currentPage: 1,\r\n            pageSize: 10,\r\n            totalItems: null,\r\n            categoryClick: { id: null, name: 'All' }\r\n        }\r\n    },\r\n    created() {\r\n        this.fetchCategoryData();\r\n        this.fetchGourmetData();\r\n    },\r\n    methods: {\r\n        readGourmet(gourmet){\r\n            sessionStorage.setItem('gourmetId',gourmet.id);\r\n            this.$router.push();\r\n        },\r\n        handleFilterClear() {\r\n            this.filterText = '';\r\n            this.fetchGourmetData();\r\n        },\r\n        // 页面大小改变\r\n        handleSizeChange(val) {\r\n            this.pageSize = val;\r\n            this.currentPage = 1;\r\n            this.fetchGourmetData();\r\n        },\r\n        // 当前页切换\r\n        handleCurrentChange(val) {\r\n            this.currentPage = val;\r\n            this.fetchGourmetData();\r\n        },\r\n        // 选择分类\r\n        categorySelected(category) {\r\n            this.categoryClick = category;\r\n            this.gourmetQueryDto.categoryId = category.id;\r\n            this.fetchGourmetData();\r\n        },\r\n        // 获取美食分类\r\n        fetchCategoryData() {\r\n            this.$axios.post('category/query', {}).then(res => {\r\n                const { data } = res;\r\n                if (data.code === 200) {\r\n                    this.categories = res.data.data;\r\n                    this.categories.unshift(this.categoryClick);\r\n                }\r\n            }).catch(error => {\r\n                console.log(error);\r\n            });\r\n        },\r\n\r\n        // 获取美食做法(既公开又审核通过的)\r\n        fetchGourmetData() {\r\n            // 请求参数\r\n            const queryDto = {\r\n                current: this.currentPage,\r\n                size: this.pageSize,\r\n                key: this.filterText,\r\n                ...this.gourmetQueryDto\r\n            };\r\n            this.$axios.post('gourmet/queryList', queryDto).then(res => {\r\n                const { data } = res;\r\n                if (data.code === 200) {\r\n                    this.gourmetList = res.data.data;\r\n                    this.totalItems = data.total;\r\n                }\r\n            }).catch(error => {\r\n                console.log(error);\r\n            });\r\n        }\r\n    }\r\n};\r\n</script>\r\n<style scoped lang=\"scss\">\r\n.item-category {\r\n    display: inline-block;\r\n    padding: 4px 12px;\r\n    margin-right: 8px;\r\n    background-color: aliceblue;\r\n    border-radius: 5px;\r\n    font-size: 18px;\r\n    cursor: pointer;\r\n}\r\n\r\n.item-gourmet:hover {\r\n    background-color: rgb(245, 245, 245);\r\n}\r\n\r\n.item-gourmet {\r\n    display: flex;\r\n    justify-content: left;\r\n    gap: 10px;\r\n    padding: 10px;\r\n    border-radius: 5px;\r\n    cursor: pointer;\r\n\r\n    .left {\r\n        img {\r\n            width: 220px;\r\n            border-radius: 5px;\r\n            height: 150px;\r\n        }\r\n\r\n    }\r\n\r\n    .right {\r\n        text-align: left;\r\n\r\n        .title:hover {\r\n            text-decoration: underline;\r\n        }\r\n\r\n        .title {\r\n            padding: 4px 6px;\r\n            font-size: 20px;\r\n            font-weight: bold;\r\n\r\n        }\r\n\r\n        .detail {\r\n            margin-top: 10px;\r\n            padding: 4px 6px;\r\n            font-size: 15px;\r\n            color: #333232;\r\n            display: flex;\r\n            justify-content: left;\r\n            gap: 10px;\r\n        }\r\n\r\n        .info {\r\n            padding: 4px 6px;\r\n            display: flex;\r\n            justify-content: left;\r\n            align-items: center;\r\n            gap: 5px;\r\n            font-size: 15px;\r\n        }\r\n    }\r\n}\r\n</style>\r\n"],"sourceRoot":"src/views/user"}]}