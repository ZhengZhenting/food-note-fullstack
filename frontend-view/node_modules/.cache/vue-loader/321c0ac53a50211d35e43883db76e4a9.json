{"remainingRequest":"C:\\Users\\zhent\\Desktop\\Project\\food-note-fullstack\\frontend-view\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!C:\\Users\\zhent\\Desktop\\Project\\food-note-fullstack\\frontend-view\\src\\views\\user\\Gourmet.vue?vue&type=style&index=0&id=b8fd6926&scoped=true&lang=scss&","dependencies":[{"path":"C:\\Users\\zhent\\Desktop\\Project\\food-note-fullstack\\frontend-view\\src\\views\\user\\Gourmet.vue","mtime":1772714666899},{"path":"C:\\Users\\zhent\\Desktop\\Project\\food-note-fullstack\\frontend-view\\node_modules\\css-loader\\dist\\cjs.js","mtime":1771949759462},{"path":"C:\\Users\\zhent\\Desktop\\Project\\food-note-fullstack\\frontend-view\\node_modules\\vue-loader\\lib\\loaders\\stylePostLoader.js","mtime":1771949761291},{"path":"C:\\Users\\zhent\\Desktop\\Project\\food-note-fullstack\\frontend-view\\node_modules\\postcss-loader\\src\\index.js","mtime":1771949760157},{"path":"C:\\Users\\zhent\\Desktop\\Project\\food-note-fullstack\\frontend-view\\node_modules\\sass-loader\\dist\\cjs.js","mtime":1771949761839},{"path":"C:\\Users\\zhent\\Desktop\\Project\\food-note-fullstack\\frontend-view\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1771949758934},{"path":"C:\\Users\\zhent\\Desktop\\Project\\food-note-fullstack\\frontend-view\\node_modules\\vue-loader\\lib\\index.js","mtime":1771949760655}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["Gourmet.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAyIA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;;AAEA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"Gourmet.vue","sourceRoot":"src/views/user","sourcesContent":["<template>\r\n    <div class=\"text\">\r\n        <div>\r\n            <div style=\"height: 200px; background-color: #f0f0f0; text-align: center;\">\r\n                <h2>recommendationes //TODO</h2>\r\n            </div>\r\n            <div style=\"text-align: left; display: block; margin: 20px 0;\">\r\n                <span style=\"font-size: 24px; font-weight: bold;\"> Search </span>\r\n                <el-input size=\"small\" style=\"width: 166px;\" v-model=\"gourmetQueryDto.title\" placeholder=\"title\"\r\n                    clearable @clear=\"handleFilterClear\">\r\n                    <el-button slot=\"append\" @click=\"fetchGourmetData\" icon=\"el-icon-search\"></el-button>\r\n                </el-input>\r\n            </div>\r\n            <div style=\"margin-block: 20px; text-align: left; display: block;\">\r\n                <span :style=\"{\r\n                    backgroundColor: categoryClick.id === category.id ? '#0d559e' : '',\r\n                    color: categoryClick.id === category.id ? 'rgb(245,245,245)' : ''\r\n                }\" @click=\"categorySelected(category)\" class=\"item-category\" v-for=\"(category, index) in categories\"\r\n                    :key=\"index\">\r\n                    {{ category.name }}\r\n                </span>\r\n            </div>\r\n            <div v-if=\"gourmetList.length === 0\">\r\n                <el-empty description=\"No data\"></el-empty>\r\n            </div>\r\n            <div>\r\n                <div class=\"item-gourmet\" v-for=\"(gourmet, index) in gourmetList\" :key=\"index\">\r\n                    <div class=\"left\">\r\n                        <img :src=\"gourmet.cover\">\r\n                    </div>\r\n                    <div class=\"right\">\r\n                        <div class=\"info\">\r\n                            <img style=\"width: 25px; height: 25px; border-radius: 50%;\" :src=\"gourmet.userAvatar\">\r\n                            <span>{{ gourmet.userName }}</span>\r\n                        </div>\r\n                        <div class=\"title\">\r\n                            {{ gourmet.title }}\r\n                        </div>\r\n                        <div class=\"detail\">\r\n                            {{ gourmet.detail }}\r\n                        </div>\r\n                        <div class=\"detail\">\r\n                            <span> {{ gourmet.createTime }}</span>\r\n                            <span> Views({{ gourmet.viewCount }})</span>\r\n                            <span> Likes({{ gourmet.upvoteCount }})</span>\r\n                            <span> Saves({{ gourmet.saveCount }})</span>\r\n                            <span> Rating({{ gourmet.rating }})</span>\r\n                        </div>\r\n                    </div>\r\n\r\n                </div>\r\n            </div>\r\n            <el-pagination style=\"margin:10px 0;float: right;\" @size-change=\"handleSizeChange\"\r\n                @current-change=\"handleCurrentChange\" :current-page=\"currentPage\" :page-sizes=\"[10, 20]\"\r\n                :page-size=\"pageSize\" layout=\"total, sizes, prev, pager, next, jumper\"\r\n                :total=\"totalItems\"></el-pagination>\r\n        </div>\r\n\r\n    </div>\r\n</template>\r\n<script>\r\nexport default {\r\n    name: \"Gourmet\",\r\n    data() {\r\n        return {\r\n            gourmetQueryDto: {},\r\n            gourmetList: [],\r\n            categories: [],\r\n            filterText: '',\r\n            currentPage: 1,\r\n            pageSize: 10,\r\n            totalItems: null,\r\n            categoryClick: { id: null, name: 'All' }\r\n        }\r\n    },\r\n    created() {\r\n        this.fetchCategoryData();\r\n        this.fetchGourmetData();\r\n    },\r\n    methods: {\r\n        handleFilterClear() {\r\n            this.filterText = '';\r\n            this.fetchGourmetData();\r\n        },\r\n        // 页面大小改变\r\n        handleSizeChange(val) {\r\n            this.pageSize = val;\r\n            this.currentPage = 1;\r\n            this.fetchGourmetData();\r\n        },\r\n        // 当前页切换\r\n        handleCurrentChange(val) {\r\n            this.currentPage = val;\r\n            this.fetchGourmetData();\r\n        },\r\n        // 选择分类\r\n        categorySelected(category) {\r\n            this.categoryClick = category;\r\n            this.gourmetQueryDto.categoryId = category.id;\r\n            this.fetchGourmetData();\r\n        },\r\n        // 获取美食分类\r\n        fetchCategoryData() {\r\n            this.$axios.post('category/query', {}).then(res => {\r\n                const { data } = res;\r\n                if (data.code === 200) {\r\n                    this.categories = res.data.data;\r\n                    this.categories.unshift(this.categoryClick);\r\n                }\r\n            }).catch(error => {\r\n                console.log(error);\r\n            });\r\n        },\r\n\r\n        // 获取美食做法(既公开又审核通过的)\r\n        fetchGourmetData() {\r\n            // 请求参数\r\n            const queryDto = {\r\n                current: this.currentPage,\r\n                size: this.pageSize,\r\n                key: this.filterText,\r\n                ...this.gourmetQueryDto\r\n            };\r\n            this.$axios.post('gourmet/queryList', queryDto).then(res => {\r\n                const { data } = res;\r\n                if (data.code === 200) {\r\n                    this.gourmetList = res.data.data;\r\n                    this.totalItems = data.total;\r\n                }\r\n            }).catch(error => {\r\n                console.log(error);\r\n            });\r\n        }\r\n    }\r\n};\r\n</script>\r\n<style scoped lang=\"scss\">\r\n.item-category {\r\n    display: inline-block;\r\n    padding: 4px 12px;\r\n    margin-right: 8px;\r\n    background-color: aliceblue;\r\n    border-radius: 5px;\r\n    font-size: 18px;\r\n    cursor: pointer;\r\n}\r\n\r\n.item-gourmet:hover {\r\n    background-color: rgb(245, 245, 245);\r\n}\r\n\r\n.item-gourmet {\r\n    display: flex;\r\n    justify-content: left;\r\n    gap: 10px;\r\n    padding: 10px;\r\n    border-radius: 5px;\r\n    cursor: pointer;\r\n\r\n    .left {\r\n        img {\r\n            width: 220px;\r\n            border-radius: 5px;\r\n            height: 150px;\r\n        }\r\n\r\n    }\r\n\r\n    .right {\r\n        text-align: left;\r\n\r\n        .title :hover{\r\n            text-decoration: underline;\r\n        }\r\n        .title{\r\n            padding: 4px 6px;\r\n            font-size: 20px;\r\n            font-weight: bold;\r\n\r\n        }\r\n\r\n        .detail {\r\n            margin-top: 10px;\r\n            padding: 4px 6px;\r\n            font-size: 15px;\r\n            color: #333232;\r\n            display: flex;\r\n            justify-content: left;\r\n            gap:10px;\r\n        }\r\n\r\n        .info {\r\n            padding: 4px 6px;\r\n            display: flex;\r\n            justify-content: left;\r\n            align-items: center;\r\n            gap: 5px;\r\n            font-size: 15px;\r\n        }\r\n    }\r\n}\r\n</style>\r\n"]}]}