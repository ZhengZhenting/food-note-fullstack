<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.kmbeast.mapper.GourmetMapper">
    <insert id="save">
        INSERT INTO gourmet(user_id, category_id, title, content, cover, is_audit, is_publish, create_time)
            VALUES(#{userId},#{categoryId},#{title}, #{content}, #{cover}, #{isAudit}, #{isPublish}, #{createTime})
    </insert>
    <update id="update">
        UPDATE gourmet
        <set>
            <if test="userId != null">
                user_id = #{userId},
            </if>
            <if test="categoryId != null">
                category_id = #{categoryId},
            </if>
            <if test="title != null and title != ''">
                title = #{title},
            </if>
            <if test="content != null and content != ''">
                content = #{content},
            </if>
            <if test="cover != null and cover != ''">
                cover = #{cover},
            </if>
            <if test="isAudit != null">
                is_audit = #{isAudit},
            </if>
            <if test="isPublish != null">
                is_publish = #{isPublish},
            </if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="batchDelete" parameterType="list">
        DELETE FROM gourmet WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <!--search-->
    <select id="query" resultMap="BaseResultMap" >

        SELECT g.*, c.name AS category_name, u.user_name, u.user_avatar
        FROM gourmet g
        LEFT JOIN category c ON g.category_id = c.id
        LEFT JOIN user u ON g.user_id = u.id
        <where>
            <if test="id != null">
                AND g.id = #{id}
            </if>
            <if test="categoryId != null">
                AND g.category_id = #{categoryId}
            </if>
            <if test="userId != null">
                AND g.user_id = #{userId}
            </if>
            <if test="title != null and title != ''">
                AND g.title LIKE concat('%',#{title},'%')
            </if>
            <if test="isAudit != null">
                AND g.is_audit = #{isAudit}
            </if>
            <if test="isPublish != null">
                AND g.is_publish = #{isPublish}
            </if>
            <if test="startTime != null and endTime != null">
                AND g.create_time BETWEEN #{startTime} AND #{endTime}
            </if>
        </where>
        ORDER BY g.id DESC
        <if test="current != null and size != null">
            LIMIT #{current},#{size}
        </if>
    </select>

    <!--满足分页条件的数据总项-->
    <select id="queryCount" resultType="integer">
        SELECT COUNT(*)
        FROM gourmet g
        <where>
            <if test="id != null">
                AND g.id = #{id}
            </if>
            <if test="categoryId != null">
                AND g.category_id = #{categoryId}
            </if>
            <if test="userId != null">
                AND g.user_id = #{userId}
            </if>
            <if test="title != null and title != ''">
                AND g.title LIKE concat('%',#{title},'%')
            </if>
            <if test="isAudit != null">
                AND g.is_audit = #{isAudit}
            </if>
            <if test="isPublish != null">
                AND g.is_publish = #{isPublish}
            </if>
            <if test="startTime != null and endTime != null">
                AND g.create_time BETWEEN #{startTime} AND #{endTime}
            </if>
        </where>
    </select>

    <!-- mapping result of searching -->
    <resultMap id="BaseResultMap" type="cn.kmbeast.pojo.vo.GourmetVO">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="category_id" property="categoryId"/>
        <result column="title" property="title"/>
        <result column="content" property="content"/>
        <result column="cover" property="cover"/>
        <result column="is_audit" property="isAudit"/>
        <result column="is_publish" property="isPublish"/>
        <result column="create_time" property="createTime"/>
        <result column="category_name" property="categoryName"/>
        <result column="user_name" property="userName"/>
        <result column="user_avatar" property="userAvatar"/>
    </resultMap>


</mapper>
